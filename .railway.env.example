# ──────────────────────────────────────────────────────────────────────────────
# CricEdge — Railway Environment Variables
# Copy to Railway dashboard → each service → Variables
# ──────────────────────────────────────────────────────────────────────────────

# App
APP_ENV=production
SECRET_KEY=generate-a-long-random-string-at-least-32-chars

# ── Database ──
# Railway Postgres plugin provides DATABASE_URL automatically.
# Format: postgresql+asyncpg://user:pass@host:5432/cricedge
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/cricedge

# ── Redis ──
# Railway Redis plugin provides REDIS_URL automatically.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Supabase (auth) ──
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Razorpay (payments) ──
# Found in: Razorpay dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your-secret

# ── External APIs ──
# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-key

# Twitter / X Developer Portal: https://developer.twitter.com
TWITTER_BEARER_TOKEN=your-token

# ── CORS ──
# Comma-separated allowed origins for the frontend domain
ALLOWED_ORIGINS=https://cricedge.in,https://www.cricedge.in

# ── Frontend (Next.js public vars) ──
# PostHog: https://app.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_API_URL=https://cricedge.in
